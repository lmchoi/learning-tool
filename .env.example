ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Path to the chunk store (embeddings + sessions). Used by both API and CLI.
# Defaults to contexts/store relative to cwd. Accepts absolute or relative paths
# (relative paths resolve from cwd). Set to an absolute path to share data across
# git worktrees or keep it outside the repo entirely.
# STORE_DIR=/path/to/your/store

# Model overrides — defaults to claude-haiku-4-5 if unset
# QUESTION_GENERATION_MODEL=claude-haiku-4-5
# ANSWER_EVALUATION_MODEL=claude-haiku-4-5

# GitHub escalation (optional — feature is hidden in UI if unset)
# GITHUB_TOKEN=your-github-personal-access-token  # needs repo scope
# GITHUB_REPO=owner/repo-name                     # e.g. lmchoi/learning-tool
